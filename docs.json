{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "Daekan Documentation",
  "colors": {
    "primary": "#ff9100",
    "light": "#ffa300",
    "dark": "#ffb000"
  },
  "favicon": {
    "light": "/images/cropped-ico-app-daekan.png",
    "dark": "/images/cropped-ico-app-daekan.png"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guide",
        "groups": [
          {
            "group": "Mulai di sini",
            "pages": [
              "index",
              "quickstart",
              "guides/platform-overview",
              "guides/order-management"
            ]
          },
          {
            "group": "Penjualan & operasional",
            "pages": [
              "guides/payment-links",
              "guides/digital-products",
              "guides/team-management"
            ]
          },
          {
            "group": "Growth & tracking",
            "pages": [
              "guides/capi-integration",
              "guides/troubleshooting"
            ]
          },
          {
            "group": "Dokumentasi internal",
            "pages": [
              "development"
            ]
          }
        ],
        "icon": "olive-branch"
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Dasar",
            "pages": [
              "api-reference/introduction",
              "api-reference/authentication"
            ]
          },
          {
            "group": "Core endpoints",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/product",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ],
        "icon": "code"
      },
      {
        "tab": "Blog",
        "groups": [
          {
            "group": "Artikel terbaru",
            "pages": [
              "blog/building-smart-order-ops",
              "blog/reducing-lost-checkouts",
              "blog/capi-for-performance-marketing"
            ]
          }
        ],
        "icon": "newspaper"
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://daekan.app",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Support",
          "href": "mailto:support@daekan.app",
          "icon": "life-ring"
        }
      ]
    }
  },
  "logo": {
    "light": "/images/daekan-app-hor.png",
    "dark": "/images/DAEKANPUTIHLOgo.png",
    "href": "https://daekan.app"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@daekan.app"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Buka Daekan",
      "href": "https://daekan.app"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "icons": {
    "library": "fontawesome"
  },
  "background": {
    "decoration": "gradient"
  },
  "fonts": {
    "family": "Plus Jakarta Sans"
  }
